<%- include('partials/header') %>

<%
    const detailAssessment =
        (typeof assessment !== 'undefined' && assessment) ||
        (typeof selectedAssessment !== 'undefined' && selectedAssessment) ||
        null;
    const detailType =
        (typeof type !== 'undefined' && type) ||
        (detailAssessment && detailAssessment.assessment_type) ||
        null;
    const answerRows =
        (typeof answers !== 'undefined' && Array.isArray(answers) && answers) ||
        (typeof questions !== 'undefined' && Array.isArray(questions) && questions) ||
        [];
%>

<div class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
    <%- include('partials/flash-messages') %>

    <section class="mb-7 rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card sm:p-6">
        <h2 class="text-2xl font-extrabold text-white sm:text-3xl">Submission Detail</h2>
        <p class="mt-2 text-slate-300">Review student answers question by question.</p>

        <div class="mt-5 grid grid-cols-1 gap-3 text-sm sm:grid-cols-2">
            <div class="rounded-xl border border-slate-800 bg-slate-950/80 p-3 text-slate-300"><strong>Assessment:</strong> <%= detailAssessment ? detailAssessment.title : 'N/A' %></div>
            <div class="rounded-xl border border-slate-800 bg-slate-950/80 p-3 text-slate-300"><strong>Student:</strong> <%= submission.full_name %> (<%= submission.username %>)</div>
            <div class="rounded-xl border border-slate-800 bg-slate-950/80 p-3 text-slate-300"><strong>Submitted:</strong> <%= new Date(submission.submitted_at).toLocaleString() %></div>
            <div class="rounded-xl border border-slate-800 bg-slate-950/80 p-3 text-slate-300"><strong>Score:</strong> <span class="font-bold text-cyan-300"><%= submission.score %>/<%= submission.total_questions || (detailAssessment && detailAssessment.max_score) || '-' %></span></div>
        </div>

        <% if (detailAssessment && detailType) { %>
            <a href="/teacher/assessment-results/<%= detailType %>/<%= detailAssessment.id %>" class="mt-5 inline-flex rounded-xl border border-cyan-500/60 px-4 py-2 text-sm font-semibold text-cyan-300 transition hover:bg-cyan-500/15">← Back to Results</a>
        <% } else { %>
            <a href="/teacher/assessment-results" class="mt-5 inline-flex rounded-xl border border-cyan-500/60 px-4 py-2 text-sm font-semibold text-cyan-300 transition hover:bg-cyan-500/15">← Back to Results</a>
        <% } %>
    </section>

    <section class="space-y-4">
        <% answerRows.forEach((answer, index) => { %>
            <article class="rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card sm:p-5">
                <h3 class="text-lg font-semibold text-white">Question <%= index + 1 %></h3>
                <p class="mt-2 text-slate-200"><%= answer.question_text %></p>

                <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
                    <div class="rounded-xl border border-slate-700 bg-slate-950/80 p-3 text-sm text-slate-200"><strong>Student Answer:</strong> <%= answer.student_answer || answer.selected_answer || 'No answer' %></div>
                    <div class="rounded-xl border border-slate-700 bg-slate-950/80 p-3 text-sm text-slate-200"><strong>Correct Answer:</strong> <%= answer.correct_answer %></div>
                </div>

                <div class="mt-3">
                    <% if (answer.is_correct) { %>
                        <span class="rounded-full border border-emerald-400/40 bg-emerald-500/10 px-3 py-1 text-xs font-semibold text-emerald-200">Correct</span>
                    <% } else { %>
                        <span class="rounded-full border border-rose-400/40 bg-rose-500/10 px-3 py-1 text-xs font-semibold text-rose-200">Incorrect</span>
                    <% } %>
                </div>
            </article>
        <% }); %>
    </section>
</div>

<%- include('partials/footer') %>
