<%- include('partials/header') %>

<div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <%- include('partials/flash-messages') %>

    <section class="mb-8 rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card sm:p-6">
        <h2 class="text-2xl font-extrabold text-white sm:text-3xl">My Classrooms</h2>
        <p class="mt-2 text-slate-300">Create and manage classroom spaces for your students.</p>
    </section>

    <section class="mb-8 rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card sm:p-6">
        <h3 class="text-xl font-bold text-white">Create New Classroom</h3>
        <form action="/teacher/create-classroom" method="POST" class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2">
            <div>
                <label for="class_name" class="mb-2 block text-sm font-semibold text-slate-200">Class Name *</label>
                <input type="text" id="class_name" name="class_name" placeholder="e.g., Grade 8-A Mathematics" required class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-slate-100 placeholder:text-slate-500 focus:border-cyan-400 focus:outline-none">
            </div>
            <div>
                <label for="subject" class="mb-2 block text-sm font-semibold text-slate-200">Subject *</label>
                <input type="text" id="subject" name="subject" placeholder="e.g., Mathematics" required class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-slate-100 placeholder:text-slate-500 focus:border-cyan-400 focus:outline-none">
            </div>
            <div>
                <label for="grade_level" class="mb-2 block text-sm font-semibold text-slate-200">Grade Level *</label>
                <input type="text" id="grade_level" name="grade_level" placeholder="e.g., 8" required class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-slate-100 placeholder:text-slate-500 focus:border-cyan-400 focus:outline-none">
            </div>
            <div class="md:col-span-2">
                <button type="submit" class="rounded-xl bg-cyan-500 px-5 py-3 text-sm font-bold text-slate-950 transition hover:bg-cyan-400">Create Classroom</button>
            </div>
        </form>
    </section>

    <section>
        <h3 class="mb-4 text-xl font-bold text-white">Existing Classrooms</h3>
        <% if (classrooms && classrooms.length > 0) { %>
            <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                <% classrooms.forEach((classroom) => { %>
                    <article class="rounded-2xl border border-slate-800 bg-slate-900/85 p-5 shadow-card">
                        <h4 class="text-lg font-bold text-cyan-300"><%= classroom.class_name %></h4>
                        <p class="mt-2 text-sm text-slate-300"><strong>Subject:</strong> <%= classroom.subject %></p>
                        <p class="text-sm text-slate-300"><strong>Grade:</strong> <%= classroom.grade_level %></p>
                        <p class="text-sm text-slate-300"><strong>Class Code:</strong> <span class="font-bold text-emerald-300"><%= classroom.class_code %></span></p>
                        <p class="text-sm text-slate-300"><strong>Students:</strong> <%= classroom.student_count || 0 %></p>
                    </article>
                <% }); %>
            </div>
        <% } else { %>
            <div class="rounded-xl border border-slate-800 bg-slate-900/85 p-5 text-slate-300">No classrooms created yet. Create your first classroom above.</div>
        <% } %>
    </section>
</div>

<%- include('partials/footer') %>
