<%- include('partials/header') %>

<div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <section class="mb-8 rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card sm:p-6">
        <h2 class="text-2xl font-extrabold text-white sm:text-3xl"><%= category.charAt(0).toUpperCase() + category.slice(1) %> Topics</h2>
        <p class="mt-2 text-slate-300">Select a topic to start your mission.</p>
    </section>

    <section class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
        <% if (topics.length > 0) { %>
            <% topics.forEach(topic => { %>
                <div class="relative rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card transition duration-300 hover:-translate-y-1 hover:border-cyan-400/50 hover:shadow-glow sm:p-6">
                    <span class="absolute right-4 top-4 rounded-full border border-cyan-400/40 bg-cyan-400/10 px-3 py-1 text-xs font-semibold text-cyan-200">Grade <%= topic.grade_level %></span>
                    <h3 class="pr-20 text-xl font-bold text-white"><%= topic.topic_name %></h3>
                    <p class="mt-3 text-sm leading-relaxed text-slate-300"><%= topic.description %></p>
                    <% if (topic.first_mission_id) { %>
                        <a href="/mission/<%= topic.first_mission_id %>" class="mt-5 inline-flex rounded-xl bg-cyan-500 px-4 py-2 text-sm font-bold text-slate-950 transition duration-300 hover:bg-cyan-400">Start Mission</a>
                    <% } else { %>
                        <span class="mt-5 inline-flex rounded-xl border border-slate-700 bg-slate-800 px-4 py-2 text-sm font-semibold text-slate-400">No Mission Yet</span>
                    <% } %>
                </div>
            <% }); %>
        <% } else { %>
            <div class="rounded-xl border border-slate-800 bg-slate-900/85 p-4 text-slate-300 sm:p-6">No topics found for this category yet. Check back soon.</div>
        <% } %>
    </section>
</div>

<%- include('partials/footer') %>
