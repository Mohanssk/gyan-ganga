<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#020617">
    <title>Gyan Ganga</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            400: '#22d3ee',
                            500: '#06b6d4',
                            600: '#0891b2'
                        }
                    },
                    boxShadow: {
                        glow: '0 0 0 1px rgba(34, 211, 238, 0.35), 0 0 26px rgba(6, 182, 212, 0.25)',
                        card: '0 18px 48px rgba(2, 6, 23, 0.45)'
                    },
                    keyframes: {
                        fadeInUp: {
                            '0%': { opacity: '0', transform: 'translateY(14px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' }
                        }
                    },
                    animation: {
                        'fade-in-up': 'fadeInUp 700ms ease-out both'
                    }
                }
            }
        };
    </script>
    <link rel="manifest" href="/manifest.json">
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen bg-slate-950 text-slate-100 [font-family:Poppins,sans-serif]">
    <header class="sticky top-0 z-40 border-b border-slate-800/70 bg-slate-950/90 backdrop-blur-lg">
        <div class="mx-auto flex w-full max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-4 sm:flex-nowrap sm:px-6 lg:px-8">
            <a href="/" class="text-lg font-extrabold tracking-tight text-slate-100 transition-colors duration-300 hover:text-cyan-300 sm:text-xl">Gyan Ganga 📖</a>
            <nav class="flex items-center gap-2 sm:gap-3">
                <% if (typeof user !== 'undefined' && user) { %>
                    <details class="relative">
                        <summary class="list-none cursor-pointer rounded-xl border border-cyan-400/30 bg-slate-900 px-3 py-2 text-xs font-semibold text-cyan-200 shadow-glow transition duration-300 hover:bg-slate-800 sm:px-4 sm:text-sm">Welcome, <%= user.full_name %> ▼</summary>
                        <div class="absolute right-0 mt-2 w-44 overflow-hidden rounded-xl border border-slate-700/70 bg-slate-900 shadow-2xl">
                            <a class="block px-4 py-3 text-sm text-slate-100 transition-colors duration-200 hover:bg-slate-800" href="/profile">Profile</a>
                            <a class="block px-4 py-3 text-sm text-slate-100 transition-colors duration-200 hover:bg-slate-800" href="/dashboard">Dashboard</a>
                            <a class="block px-4 py-3 text-sm text-slate-100 transition-colors duration-200 hover:bg-slate-800" href="/logout">Logout</a>
                        </div>
                    </details>
                <% } else { %>
                    <a href="/login" class="rounded-lg border border-cyan-500/60 px-3 py-2 text-xs font-semibold text-cyan-300 transition duration-300 hover:bg-cyan-500/15 sm:px-4 sm:text-sm">Login</a>
                    <a href="/signup" class="rounded-lg bg-cyan-500 px-3 py-2 text-xs font-semibold text-slate-950 transition duration-300 hover:-translate-y-0.5 hover:bg-cyan-400 sm:px-4 sm:text-sm">Sign Up</a>
                <% } %>
            </nav>
        </div>
    </header>
    <main>
