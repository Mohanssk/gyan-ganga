<% if (messages && messages.success) { %>
    <div class="mx-auto mb-4 w-full max-w-3xl rounded-xl border border-emerald-400/30 bg-emerald-500/10 px-4 py-3 text-sm font-medium text-emerald-200 shadow-glow">
        <%= messages.success %>
    </div>
<% } %>

<% if (messages && messages.error) { %>
    <div class="mx-auto mb-4 w-full max-w-3xl rounded-xl border border-rose-400/30 bg-rose-500/10 px-4 py-3 text-sm font-medium text-rose-200 shadow-glow">
        <%= messages.error %>
    </div>
<% } %>
