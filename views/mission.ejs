<%- include('partials/header') %>

<div class="mx-auto w-full max-w-7xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
    <% if (missions && missions.length > 0) { %>
        <div class="mb-6 rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card sm:p-6">
            <h2 class="text-2xl font-extrabold leading-tight text-white sm:text-3xl"><%= topic_name %></h2>
            <p class="mt-2 text-sm leading-relaxed text-slate-300 sm:text-base"><%= category.charAt(0).toUpperCase() + category.slice(1) %> | Grade <%= grade_level %></p>
        </div>

        <div class="grid grid-cols-1 gap-6 xl:grid-cols-[minmax(0,1fr)_340px]">
            <section class="space-y-4">
                <article class="rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card sm:p-5">
                    <h3 id="mission-title" class="text-xl font-bold leading-tight text-white sm:text-2xl"></h3>
                    <p id="mission-description" class="mt-2 text-sm leading-relaxed text-slate-300 sm:text-base"></p>
                </article>

                <article class="rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card sm:p-5">
                    <h4 class="mb-3 text-lg font-semibold text-slate-100">Video Lesson</h4>
                    <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-950">
                        <video id="mission-video-player" controls class="h-auto w-full"></video>
                    </div>
                    <div class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-6">
                        <button id="play-pause-btn" class="h-10 rounded-lg border border-slate-700 bg-slate-900 px-3 text-xs font-semibold leading-none text-slate-100 transition hover:bg-slate-800">Play/Pause</button>
                        <button id="rewind-btn" class="h-10 rounded-lg border border-slate-700 bg-slate-900 px-3 text-xs font-semibold leading-none text-slate-100 transition hover:bg-slate-800">-10s</button>
                        <button id="forward-btn" class="h-10 rounded-lg border border-slate-700 bg-slate-900 px-3 text-xs font-semibold leading-none text-slate-100 transition hover:bg-slate-800">+10s</button>
                        <select id="speed-select" class="h-10 rounded-lg border border-slate-700 bg-slate-900 px-3 text-xs font-semibold leading-none text-slate-100 focus:border-cyan-400 focus:outline-none">
                            <option value="0.5">0.5x</option>
                            <option value="1" selected>1x</option>
                            <option value="1.5">1.5x</option>
                            <option value="2">2x</option>
                        </select>
                        <button id="pip-btn" class="h-10 rounded-lg border border-slate-700 bg-slate-900 px-3 text-xs font-semibold leading-none text-slate-100 transition hover:bg-slate-800">PiP</button>
                        <button id="fullscreen-btn" class="h-10 rounded-lg border border-slate-700 bg-slate-900 px-3 text-xs font-semibold leading-none text-slate-100 transition hover:bg-slate-800">Fullscreen</button>
                    </div>
                    <div class="mt-4 rounded-xl border border-slate-800 bg-slate-950/80 p-4">
                        <label for="volume-range" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Volume</label>
                        <input id="volume-range" type="range" min="0" max="1" step="0.1" value="1" class="w-full accent-cyan-400">
                    </div>
                </article>

                <article class="rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card sm:p-5">
                    <h4 class="mb-3 text-lg font-semibold text-slate-100">Notes</h4>
                    <textarea id="notes-area" placeholder="Write your notes here..." class="h-40 w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-slate-100 placeholder:text-slate-500 focus:border-cyan-400 focus:outline-none"></textarea>
                    <div class="mt-3 flex flex-wrap gap-3">
                        <button id="save-notes-btn" class="h-10 rounded-xl bg-cyan-500 px-4 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400">Save Notes</button>
                        <button id="download-notes-btn" class="h-10 rounded-xl border border-slate-600 px-4 text-sm font-semibold text-slate-200 transition hover:bg-slate-800">Download Notes</button>
                    </div>
                </article>
            </section>

            <aside class="rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card sm:p-5">
                <h4 class="mb-4 text-lg font-bold text-white">Mission List</h4>
                <div id="mission-sidebar-list" class="space-y-2"></div>
                <div class="mt-4 rounded-xl border border-emerald-400/35 bg-emerald-500/10 p-3 text-sm font-medium text-emerald-200" id="mission-complete-message"></div>
            </aside>
        </div>
    <% } else { %>
        <div class="rounded-2xl border border-slate-800 bg-slate-900/85 p-4 text-slate-200 shadow-card sm:p-6">
            <h2 class="text-xl font-bold leading-tight text-white sm:text-2xl">No Missions Available</h2>
            <p class="mt-2 text-sm leading-relaxed text-slate-300 sm:text-base">No missions found for this topic yet. Please check back later.</p>
        </div>
    <% } %>
</div>

<script>
    const missionsData = <%- JSON.stringify(missions || []) %>;
    let currentMissionIndex = missionsData.findIndex(m => !m.is_completed);
    if (currentMissionIndex === -1) {
        currentMissionIndex = 0;
    }

    const missionTitle = document.getElementById('mission-title');
    const missionDescription = document.getElementById('mission-description');
    const missionVideoPlayer = document.getElementById('mission-video-player');
    const missionSidebarList = document.getElementById('mission-sidebar-list');
    const missionCompleteMessage = document.getElementById('mission-complete-message');
    const notesArea = document.getElementById('notes-area');

    const playPauseBtn = document.getElementById('play-pause-btn');
    const rewindBtn = document.getElementById('rewind-btn');
    const forwardBtn = document.getElementById('forward-btn');
    const speedSelect = document.getElementById('speed-select');
    const volumeRange = document.getElementById('volume-range');
    const pipBtn = document.getElementById('pip-btn');
    const fullscreenBtn = document.getElementById('fullscreen-btn');

    const saveNotesBtn = document.getElementById('save-notes-btn');
    const downloadNotesBtn = document.getElementById('download-notes-btn');

    function renderMissionSidebar() {
        if (!missionSidebarList) return;
        missionSidebarList.innerHTML = '';
        missionsData.forEach((mission, index) => {
            const missionItem = document.createElement('button');
            missionItem.className = `w-full rounded-lg border px-3 py-2 text-left text-sm font-medium transition ${
                index === currentMissionIndex ? 'border-cyan-400 bg-cyan-500/10 text-cyan-200' : 'border-slate-700 bg-slate-950 text-slate-200 hover:bg-slate-800'
            }`;
            missionItem.innerHTML = `${mission.title} ${mission.is_completed ? '<span class="ml-2 text-emerald-300">✔</span>' : ''}`;
            missionItem.disabled = !mission.is_unlocked;
            if (!mission.is_unlocked) {
                missionItem.className += ' opacity-45 cursor-not-allowed';
            }
            missionItem.onclick = () => {
                if (mission.is_unlocked) {
                    loadMission(index);
                }
            };
            missionSidebarList.appendChild(missionItem);
        });
    }

    function loadMission(index) {
        currentMissionIndex = index;
        const mission = missionsData[index];
        if (!mission) return;

        missionTitle.textContent = mission.title;
        missionDescription.textContent = mission.description;
        missionVideoPlayer.src = mission.video_path || '';

        const noteKey = `mission_notes_${mission.id}`;
        notesArea.value = localStorage.getItem(noteKey) || '';

        missionCompleteMessage.textContent = mission.is_completed ? 'Mission completed! Move to the next challenge.' : '';
        renderMissionSidebar();
    }

    async function markMissionCompleted(missionId) {
        try {
            const res = await fetch(`/mission/${missionId}/complete`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                const mission = missionsData.find(m => m.id === missionId);
                if (mission) {
                    mission.is_completed = true;
                }
                const nextMission = missionsData.find((m, i) => i > currentMissionIndex && !m.is_unlocked);
                if (nextMission) {
                    nextMission.is_unlocked = true;
                }
                renderMissionSidebar();
                missionCompleteMessage.textContent = data.message || 'Mission completed!';
            }
        } catch (error) {
            console.error('Error marking mission complete:', error);
        }
    }

    if (missionVideoPlayer) {
        missionVideoPlayer.addEventListener('ended', () => {
            const currentMission = missionsData[currentMissionIndex];
            if (currentMission && !currentMission.is_completed) {
                markMissionCompleted(currentMission.id);
            }
        });
    }

    if (playPauseBtn) {
        playPauseBtn.addEventListener('click', () => {
            if (missionVideoPlayer.paused) {
                missionVideoPlayer.play();
            } else {
                missionVideoPlayer.pause();
            }
        });
    }

    if (rewindBtn) {
        rewindBtn.addEventListener('click', () => {
            missionVideoPlayer.currentTime -= 10;
        });
    }

    if (forwardBtn) {
        forwardBtn.addEventListener('click', () => {
            missionVideoPlayer.currentTime += 10;
        });
    }

    if (speedSelect) {
        speedSelect.addEventListener('change', (e) => {
            missionVideoPlayer.playbackRate = parseFloat(e.target.value);
        });
    }

    if (volumeRange) {
        volumeRange.addEventListener('input', (e) => {
            missionVideoPlayer.volume = parseFloat(e.target.value);
        });
    }

    if (pipBtn) {
        pipBtn.addEventListener('click', async () => {
            if (document.pictureInPictureElement) {
                await document.exitPictureInPicture();
            } else if (document.pictureInPictureEnabled) {
                await missionVideoPlayer.requestPictureInPicture();
            }
        });
    }

    if (fullscreenBtn) {
        fullscreenBtn.addEventListener('click', () => {
            if (missionVideoPlayer.requestFullscreen) {
                missionVideoPlayer.requestFullscreen();
            }
        });
    }

    if (saveNotesBtn) {
        saveNotesBtn.addEventListener('click', () => {
            const currentMission = missionsData[currentMissionIndex];
            if (!currentMission) return;
            const noteKey = `mission_notes_${currentMission.id}`;
            localStorage.setItem(noteKey, notesArea.value);
            saveNotesBtn.textContent = 'Saved!';
            setTimeout(() => {
                saveNotesBtn.textContent = 'Save Notes';
            }, 1200);
        });
    }

    if (downloadNotesBtn) {
        downloadNotesBtn.addEventListener('click', () => {
            const currentMission = missionsData[currentMissionIndex];
            if (!currentMission) return;
            const blob = new Blob([notesArea.value], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `${currentMission.title.replace(/\s+/g, '_').toLowerCase()}_notes.txt`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        });
    }

    if (missionsData.length > 0) {
        loadMission(currentMissionIndex);
    }
</script>

<%- include('partials/footer') %>
