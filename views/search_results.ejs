<%- include('partials/header') %>

<div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <section class="mb-7 rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card sm:p-6">
        <h2 class="text-2xl font-extrabold text-white sm:text-3xl">Search Results</h2>
        <p class="mt-2 text-slate-300">Showing results for: <span class="font-semibold text-cyan-300">"<%= query %>"</span></p>
    </section>

    <% if (results && results.length > 0) { %>
        <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
            <% results.forEach(result => { %>
                <article class="rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card transition duration-300 hover:-translate-y-1 hover:border-cyan-400/50 hover:shadow-glow sm:p-6">
                    <h3 class="text-xl font-bold text-white"><%= result.topic_name %></h3>
                    <p class="mt-2 text-sm text-slate-300"><%= result.description %></p>
                    <div class="mt-3 flex flex-wrap gap-2 text-xs">
                        <span class="rounded-full border border-slate-700 bg-slate-950 px-3 py-1 text-slate-300"><strong>Category:</strong> <%= result.category %></span>
                        <span class="rounded-full border border-slate-700 bg-slate-950 px-3 py-1 text-slate-300"><strong>Grade:</strong> <%= result.grade_level %></span>
                    </div>
                    <a href="/mission/<%= result.id %>" class="mt-5 inline-flex rounded-xl bg-cyan-500 px-4 py-2 text-sm font-bold text-slate-950 transition hover:bg-cyan-400">Start Mission</a>
                </article>
            <% }); %>
        </div>
    <% } else { %>
        <div class="rounded-xl border border-slate-800 bg-slate-900/85 p-4 text-slate-300 sm:p-6">No results found for your search. Try a different keyword.</div>
    <% } %>
</div>

<%- include('partials/footer') %>
