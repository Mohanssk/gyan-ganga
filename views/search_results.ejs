<%- include('partials/header') %>

<%
    const currentQuery = typeof searchQuery !== 'undefined'
        ? searchQuery
        : (typeof query !== 'undefined' ? query : '');
    const topicResults = Array.isArray(topics)
        ? topics
        : (Array.isArray(results) ? results : []);
    const missionResults = Array.isArray(missions) ? missions : [];
    const videoResults = Array.isArray(videos) ? videos : [];
    const totalResults = topicResults.length + missionResults.length + videoResults.length;
%>

<div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <section class="mb-7 rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card sm:p-6">
        <h2 class="text-2xl font-extrabold text-white sm:text-3xl">Search Results</h2>
        <p class="mt-2 text-slate-300">Showing results for: <span class="font-semibold text-cyan-300">"<%= currentQuery %>"</span></p>
    </section>

    <% if (totalResults > 0) { %>
        <% if (topicResults.length > 0) { %>
            <section class="mb-8">
                <h3 class="mb-4 text-xl font-bold text-cyan-200">Topics</h3>
                <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                    <% topicResults.forEach(topic => { %>
                        <article class="rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card transition duration-300 hover:-translate-y-1 hover:border-cyan-400/50 hover:shadow-glow sm:p-6">
                            <h4 class="text-xl font-bold text-white"><%= topic.topic_name %></h4>
                            <p class="mt-2 text-sm text-slate-300"><%= topic.description || 'No description available.' %></p>
                            <div class="mt-3 flex flex-wrap gap-2 text-xs">
                                <span class="rounded-full border border-slate-700 bg-slate-950 px-3 py-1 text-slate-300"><strong>Category:</strong> <%= topic.category %></span>
                                <span class="rounded-full border border-slate-700 bg-slate-950 px-3 py-1 text-slate-300"><strong>Grade:</strong> <%= topic.grade_level %></span>
                            </div>
                            <a href="/courses/<%= topic.category %>" class="mt-5 inline-flex rounded-xl bg-cyan-500 px-4 py-2 text-sm font-bold text-slate-950 transition hover:bg-cyan-400">View Topic</a>
                        </article>
                    <% }); %>
                </div>
            </section>
        <% } %>

        <% if (missionResults.length > 0) { %>
            <section class="mb-8">
                <h3 class="mb-4 text-xl font-bold text-cyan-200">Missions</h3>
                <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                    <% missionResults.forEach(mission => { %>
                        <article class="rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card transition duration-300 hover:-translate-y-1 hover:border-cyan-400/50 hover:shadow-glow sm:p-6">
                            <h4 class="text-xl font-bold text-white"><%= mission.mission_title %></h4>
                            <p class="mt-2 text-sm text-slate-300"><%= mission.mission_description || 'No mission description available.' %></p>
                            <div class="mt-3 flex flex-wrap gap-2 text-xs">
                                <span class="rounded-full border border-slate-700 bg-slate-950 px-3 py-1 text-slate-300"><strong>Topic:</strong> <%= mission.topic_name %></span>
                                <span class="rounded-full border border-slate-700 bg-slate-950 px-3 py-1 text-slate-300"><strong>Step:</strong> <%= mission.mission_order %></span>
                            </div>
                            <a href="/mission/<%= mission.id %>" class="mt-5 inline-flex rounded-xl bg-cyan-500 px-4 py-2 text-sm font-bold text-slate-950 transition hover:bg-cyan-400">Open Mission</a>
                        </article>
                    <% }); %>
                </div>
            </section>
        <% } %>

        <% if (videoResults.length > 0) { %>
            <section>
                <h3 class="mb-4 text-xl font-bold text-cyan-200">Videos</h3>
                <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                    <% videoResults.forEach(video => { %>
                        <article class="rounded-2xl border border-slate-800 bg-slate-900/85 p-4 shadow-card transition duration-300 hover:-translate-y-1 hover:border-cyan-400/50 hover:shadow-glow sm:p-6">
                            <h4 class="text-xl font-bold text-white"><%= video.video_title %></h4>
                            <p class="mt-2 text-sm text-slate-300"><%= video.video_description || 'No video description available.' %></p>
                            <div class="mt-3 flex flex-wrap gap-2 text-xs">
                                <span class="rounded-full border border-slate-700 bg-slate-950 px-3 py-1 text-slate-300"><strong>Mission:</strong> <%= video.mission_title %></span>
                                <span class="rounded-full border border-slate-700 bg-slate-950 px-3 py-1 text-slate-300"><strong>Language:</strong> <%= video.language || 'N/A' %></span>
                            </div>
                            <a href="/mission/<%= video.mission_id %>" class="mt-5 inline-flex rounded-xl bg-cyan-500 px-4 py-2 text-sm font-bold text-slate-950 transition hover:bg-cyan-400">Watch in Mission</a>
                        </article>
                    <% }); %>
                </div>
            </section>
        <% } %>
    <% } else { %>
        <div class="rounded-xl border border-slate-800 bg-slate-900/85 p-4 text-slate-300 sm:p-6">No results found for your search. Try a different keyword.</div>
    <% } %>
</div>

<%- include('partials/footer') %>
